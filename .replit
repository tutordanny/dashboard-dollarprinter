modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \"require('concurrently').default([{command:'node server.js',cwd:'backend',name:'API'},{command:'npm run dev',cwd:'frontend',name:'Web'}],{prefix:'name',killOthers:['failure','success']})\""
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5715
externalPort = 3002
exposeLocalhost = true

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "node -e \"require('concurrently').default([{command:'node server.js',cwd:'backend',name:'API'},{command:'npm start',cwd:'frontend',name:'Web'}],{prefix:'name',killOthers:['failure','success']})\""]
build = ["bash", "-c", "cd frontend && npm run build"]
